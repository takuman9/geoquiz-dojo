# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env

# Google AI Studio (https://aistudio.google.com/apikey) で取得したAPIキー【必須】
GEMINI_API_KEY=ここにAPIキーを貼り付け

# 以下は任意(未設定なら既定値)
# 2026-07: 新規キーでは gemini-2.5-flash 不可。3.5系のGoogle検索は有料ティア限定
# (月5,000回まで無料)。無料ティアでは自動的に検索なし生成で動作します。
GEN_MODEL=gemini-3.5-flash
EMB_MODEL=gemini-embedding-001
# 429(クォータ超過)継続時に順に試す代替モデル。Gemma系は完全無料。
# 正確なIDは `node test-api.js` の[0]一覧で確認して調整してください
BACKUP_MODELS=gemini-3.1-flash-lite,gemma-4-27b-it,gemma-3-27b-it
# PORT=8080   # Cloud Run では自動設定されるので書かないこと
